---
const { title = "Logan MacAskill", pageTitle, wide = false } = Astro.props;

const path = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isHome = path === "/";
const isAbout = path === "/about";

const headerTitle = pageTitle ?? (isAbout ? "About Me" : undefined);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="stylesheet" href="/style.css" />
    <link rel="preload" href="/fonts/MapleMono-Regular.ttf.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/MapleMono-Bold.ttf.woff2" as="font" type="font/woff2" crossorigin>
  </head>

  <body>
    <main class={wide ? "wide" : ""}>
      {!isHome && (
        <header class="page-header">
          <div class="page-header-title">
            <a class="top-home" href="/" aria-label="Home">
              <img src="/favicon.svg" class="icon name-icon" alt="" width="48" height="48" />
            </a>
            {headerTitle && <h1 class="page-title">{headerTitle}</h1>}
          </div>
          <nav class="top-nav">
            <a class="filter-btn filter-link" href="/">home</a>
            {!isAbout && <a class="filter-btn filter-link" href="/about">about me</a>}
          </nav>
        </header>
      )}
      <slot />
    </main>
  </body>
</html>
