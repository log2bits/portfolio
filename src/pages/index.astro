---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const all = await getCollection("experience");

const kindPriority = { work: 0, leadership: 1, project: 2 };

const primaryKind = (entry) => {
  const kinds = entry.data.kinds ?? ["project"];
  return [...kinds].sort((a, b) => kindPriority[a] - kindPriority[b])[0];
};

const kindLabel = {
  work: "work",
  project: "project",
  leadership: "leadership",
};

const sorted = [...all].sort(
  (a, b) =>
    a.data.order - b.data.order ||
    a.data.title.localeCompare(b.data.title)
);
---

<BaseLayout title="Logan MacAskill" wide={true}>
  <header class="intro">
    <h1 class="name-line">
      <img src="/favicon.svg" class="icon name-icon" alt="" width="48" height="48" />
      <span>Logan MacAskill</span>
    </h1>
    <p class="desc">
      CS @ UC Santa Cruz. A foot in everything technical, eyes on graphics.
    </p>
  </header>

  <div class="filter-bar" aria-label="Filter by category">
    <button class="filter-btn is-active" type="button" data-filter="all">all</button>
    <button class="filter-btn kind-work" type="button" data-filter="work">work</button>
    <button class="filter-btn kind-project" type="button" data-filter="project">projects</button>
    <button class="filter-btn kind-leadership" type="button" data-filter="leadership">leadership</button>
    <a class="filter-btn filter-link" href="/about">about me</a>
  </div>

  <div class="card-grid">
    {sorted.map((e) => {
      const kinds = e.data.kinds ?? ["project"];
      const primary = primaryKind(e);
      return (
        <a
          class={`card kind-${primary}`}
          href={`/experience/${e.slug}`}
          data-kinds={kinds.join(" ")}
        >
          <div class="card-image">
            {e.data.image ? (
              <img src={e.data.image} alt="" loading="lazy" />
            ) : (
              <div class="card-image-placeholder">
                <span>{e.data.title.charAt(0)}</span>
              </div>
            )}
          </div>
          <div class="card-body">
            <div class="card-kinds">
              {kinds.map((k) => (
                <span class={`card-kind kind-${k}`}>{kindLabel[k]}</span>
              ))}
            </div>
            <h3 class="card-title">{e.data.title}</h3>
            <p class="card-desc">{e.data.desc}</p>
          </div>
        </a>
      );
    })}
  </div>

  <script is:inline>
    const buttons = document.querySelectorAll(".filter-btn[data-filter]");
    const cards = document.querySelectorAll(".card");
    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const filter = btn.dataset.filter;
        buttons.forEach((b) => b.classList.toggle("is-active", b === btn));
        cards.forEach((card) => {
          const kinds = (card.dataset.kinds || "").split(" ");
          const show = filter === "all" || kinds.includes(filter);
          card.classList.toggle("is-hidden", !show);
        });
      });
    });
  </script>
</BaseLayout>
